# .env.example — API keys for Lumina Wiki research pack tools
# Copy to .env and fill in your values. Never commit .env to git.
# Populate interactively with: /lumi-research-setup

# Semantic Scholar API key (optional; improves rate limits)
# Obtain at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex API key (optional; enables the free daily API budget and usage tracking)
# Obtain at: https://openalex.org/settings/api
OPENALEX_API_KEY=

# DeepXiv token (optional; enables full-text PDF access and semantic search)
# Obtain at: https://deepxiv.com
DEEPXIV_TOKEN=

# Scite.ai API key (optional; enables Smart Citation tallies in /lumi-research-rank)
# Obtain at: https://scite.ai/apis
SCITE_API_KEY=

# Altmetric API key (optional; enables attention scores in /lumi-research-rank)
# Obtain at: https://www.altmetric.com/products/altmetric-api/
ALTMETRIC_API_KEY=

# arXiv does not require an API key in v0.1.
# The fetcher uses the public XML API at export.arxiv.org.
