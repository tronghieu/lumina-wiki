# Normalize all text files to LF in the repo and on checkout (prevents CRLF
# issues on Windows in both test assertions and installed template content).
* text=auto eol=lf

# Explicitly binary — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
